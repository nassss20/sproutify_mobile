<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sprout_base">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="100dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <ImageView
                    android:id="@+id/imgProfilePlant"
                    android:layout_width="match_parent"
                    android:layout_height="350dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_launcher_background" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:background="@drawable/bg_gradient_top" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <ImageButton
                        android:id="@+id/btnProfileBack"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_arrow_back"
                        android:background="@drawable/bg_glow_circle"
                        android:backgroundTint="#80000000"
                        app:tint="@color/white" />

                    <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

                    <ImageButton
                        android:id="@+id/btnProfileEdit"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@android:drawable/ic_menu_edit"
                        android:background="@drawable/bg_glow_circle"
                        android:backgroundTint="#80000000"
                        app:tint="@color/white"
                        android:layout_marginEnd="8dp"/>

                    <ImageButton
                        android:id="@+id/btnProfileDelete"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@android:drawable/ic_menu_delete"
                        android:background="@drawable/bg_glow_circle"
                        android:backgroundTint="#EF5350"
                        app:tint="@color/white"/>
                </LinearLayout>
            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_top_rounded"
                android:padding="24dp"
                android:layout_marginTop="-40dp">

                <TextView
                    android:id="@+id/tvProfileName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Plant Name"
                    android:fontFamily="@font/chewy"
                    android:textSize="36sp"
                    android:textColor="@color/sprout_dark"/>

                <TextView
                    android:id="@+id/tvProfileDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Planted on: ..."
                    android:fontFamily="@font/fredoka"
                    android:textSize="16sp"
                    android:textColor="#757575"
                    android:layout_marginBottom="24dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="false">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/bg_input_field"
                        android:padding="12dp"
                        android:gravity="center"
                        android:layout_marginEnd="4dp">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_menu_sort_by_size"
                            app:tint="@color/sprout_brown"
                            android:layout_marginBottom="4dp"/>
                        <TextView
                            android:id="@+id/tvProfileHeight"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-- cm"
                            android:fontFamily="@font/fredoka"
                            android:textStyle="bold"
                            android:textColor="@color/sprout_dark"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Height" android:textSize="12sp"/>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/bg_input_field"
                        android:padding="12dp"
                        android:gravity="center"
                        android:layout_marginEnd="4dp"
                        android:layout_marginStart="4dp">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_local_florist"
                            app:tint="@color/sprout_brown"
                            android:layout_marginBottom="4dp"/>
                        <TextView
                            android:id="@+id/tvProfileWater"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:fontFamily="@font/fredoka"
                            android:textStyle="bold"
                            android:textColor="@color/sprout_dark"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Watered" android:textSize="12sp"/>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/bg_input_field"
                        android:padding="12dp"
                        android:gravity="center"
                        android:layout_marginStart="4dp">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/star_on"
                            app:tint="@color/sprout_brown"
                            android:layout_marginBottom="4dp"/>
                        <TextView
                            android:id="@+id/tvProfileFert"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:fontFamily="@font/fredoka"
                            android:textStyle="bold"
                            android:textColor="@color/sprout_dark"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Fertilized" android:textSize="12sp"/>
                    </LinearLayout>
                </LinearLayout>

                <Space android:layout_width="match_parent" android:layout_height="24dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gardener's Notes"
                    android:fontFamily="@font/chewy"
                    android:textSize="24sp"
                    android:textColor="@color/sprout_dark"/>
                <TextView
                    android:id="@+id/tvProfileNotes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No notes added."
                    android:fontFamily="@font/fredoka"
                    android:textSize="16sp"
                    android:textColor="#555555"
                    android:layout_marginTop="8dp"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#EEEEEE"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="24dp"/>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Diary Entries"
                        android:fontFamily="@font/chewy"
                        android:textSize="28sp"
                        android:textColor="@color/sprout_dark"
                        android:layout_centerVertical="true"/>

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnAddDiary"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:text="+ Entry"
                        android:background="@drawable/btn_register_bg"
                        android:backgroundTint="@color/sprout_dark"
                        android:textColor="@color/white"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:fontFamily="@font/fredoka"
                        android:textAllCaps="false"
                        android:textSize="14sp"/>
                </RelativeLayout>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="300dp"
                    android:background="@drawable/bordered_container"
                    android:padding="8dp">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvDiaryList"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scrollbars="vertical"/>
                </FrameLayout>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fabProfileGrowth"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        android:text="Track Growth"
        android:textColor="@color/white"
        app:backgroundTint="@color/sprout_dark"
        app:elevation="8dp"
        app:icon="@android:drawable/ic_menu_add"
        app:iconTint="@color/white" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
