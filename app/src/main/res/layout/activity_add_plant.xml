<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sprout_dark">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="40dp"
                app:cardElevation="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="32dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="32dp">

                        <ImageButton
                            android:id="@+id/btnBackPlant"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:src="@drawable/ic_arrow_back"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            app:tint="#BDBDBD"
                            android:layout_centerVertical="true"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Add Plant"
                            android:fontFamily="@font/chewy"
                            android:textSize="32sp"
                            android:textColor="@color/sprout_dark"
                            android:layout_centerInParent="true"/>
                    </RelativeLayout>

                    <FrameLayout
                        android:id="@+id/cardImagePicker"
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:background="@drawable/bg_image_picker"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:id="@+id/imgSelectedPlant"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="center"
                            android:src="@android:drawable/ic_menu_camera"
                            android:padding="60dp"
                            app:tint="#992F4F4F"/>
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tap to add photo"
                        android:fontFamily="@font/fredoka"
                        android:textColor="#992F4F4F"
                        android:layout_gravity="center"
                        android:layout_marginTop="8dp"/>

                    <Space android:layout_width="match_parent" android:layout_height="24dp"/>

                    <TextView
                        android:text="Plant Name *"
                        style="@style/LabelText"/>
                    <EditText
                        android:id="@+id/etPlantName"
                        style="@style/InputField"
                        android:hint="Ex: Tomato"/>

                    <Space android:layout_width="match_parent" android:layout_height="16dp"/>

                    <TextView
                        android:text="Date Planted *"
                        style="@style/LabelText"/>
                    <EditText
                        android:id="@+id/etDatePlanted"
                        style="@style/InputField"
                        android:hint="Select Date"
                        android:focusable="false"
                        android:drawableEnd="@android:drawable/ic_menu_my_calendar"/>

                    <Space android:layout_width="match_parent" android:layout_height="16dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginEnd="8dp">
                            <TextView
                                android:text="Last Watered"
                                style="@style/LabelText"/>
                            <EditText
                                android:id="@+id/etLastWatered"
                                style="@style/InputField"
                                android:hint="Select"
                                android:focusable="false"
                                android:drawableEnd="@android:drawable/ic_menu_my_calendar"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="8dp">
                            <TextView
                                android:text="Last Fertilized"
                                style="@style/LabelText"/>
                            <EditText
                                android:id="@+id/etLastFertilized"
                                style="@style/InputField"
                                android:hint="Select"
                                android:focusable="false"
                                android:drawableEnd="@android:drawable/ic_menu_my_calendar"/>
                        </LinearLayout>
                    </LinearLayout>

                    <Space android:layout_width="match_parent" android:layout_height="16dp"/>

                    <TextView
                        android:text="Height (cm)"
                        style="@style/LabelText"/>
                    <EditText
                        android:id="@+id/etHeight"
                        style="@style/InputField"
                        android:hint="Ex: 3.5"
                        android:inputType="numberDecimal"/>

                    <Space android:layout_width="match_parent" android:layout_height="16dp"/>

                    <TextView
                        android:text="Notes"
                        style="@style/LabelText"/>
                    <EditText
                        android:id="@+id/etNotes"
                        style="@style/InputField"
                        android:hint="Write something..."
                        android:minLines="3"
                        android:gravity="top"/>

                    <Space android:layout_width="match_parent" android:layout_height="32dp"/>

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnSavePlant"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:text="Save Plant"
                        android:background="@drawable/btn_register_bg"
                        android:backgroundTint="@color/sprout_dark"
                        android:fontFamily="@font/fredoka"
                        android:textStyle="bold"
                        android:textSize="20sp"
                        android:textAllCaps="false"
                        android:textColor="@color/white"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>