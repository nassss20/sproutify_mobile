<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sprout_dark">

    <View
        android:id="@+id/appBarBg"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@color/sprout_base"
        app:layout_constraintTop_toTopOf="parent"/>

    <TextView
        android:id="@+id/tvAppTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sproutify"
        android:fontFamily="@font/chewy"
        android:textSize="26sp"
        android:letterSpacing="0.05"
        android:textColor="@color/sprout_dark"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/appBarBg"
        app:layout_constraintBottom_toBottomOf="@id/appBarBg"/>

    <View
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:background="@drawable/bg_glow_circle"
        android:alpha="0.1"
        android:layout_marginBottom="100dp"
        android:layout_marginEnd="-50dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/appBarBg"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal">

            <Space android:layout_width="match_parent" android:layout_height="20dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Keep Track Of Your\nLatest Plant Within\nYour Garden"
                android:fontFamily="@font/chewy"
                android:textSize="42sp"
                android:textColor="@color/sprout_yellow"
                android:textAlignment="center"
                android:lineHeight="46dp"
                android:shadowColor="#4D000000"
                android:shadowDx="0"
                android:shadowDy="4"
                android:shadowRadius="10"/>

            <Space android:layout_width="match_parent" android:layout_height="24dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Document the arrival and initial care plan for your garden’s latest addition."
                android:fontFamily="@font/fredoka"
                android:textSize="18sp"
                android:textColor="@color/sprout_base"
                android:textAlignment="center"/>

            <Space android:layout_width="match_parent" android:layout_height="40dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnLogin"
                    android:layout_width="0dp"
                    android:layout_height="55dp"
                    android:layout_weight="1"
                    android:text="Login"
                    android:background="@drawable/btn_login_bg"
                    android:fontFamily="@font/chewy"
                    android:textSize="20sp"
                    android:textAllCaps="false"
                    android:textColor="@color/sprout_dark"
                    android:elevation="8dp"/>

                <Space android:layout_width="20dp" android:layout_height="wrap_content"/>

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnRegister"
                    android:layout_width="0dp"
                    android:layout_height="55dp"
                    android:layout_weight="1"
                    android:text="Register"
                    android:background="@drawable/btn_register_bg"
                    android:fontFamily="@font/chewy"
                    android:textSize="20sp"
                    android:textAllCaps="false"
                    android:textColor="@color/sprout_dark"
                    android:elevation="8dp"/>
            </LinearLayout>

            <Space android:layout_width="match_parent" android:layout_height="50dp"/>

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="280dp"
                android:src="@drawable/main_icon"
                android:scaleType="fitCenter"/>

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>